<div id="<%= dom_id cat %>" style="line-height: 1.6;">
  <div style="margin-bottom: 15px;">
    <% if cat.image.attached? %>
      <%= image_tag cat.image, style: "width: 100%; max-width: 400px; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);" %>
    <% else %>
      <div style="width: 100%; max-width: 400px; height: 200px; background: #eee; display: flex; align-items: center; justify-content: center; border-radius: 8px;">
        画像なし
      </div>
    <% end %>
  </div>

  <p style="font-size: 1.2em;">
    <strong>仮の名前:</strong>
    <%= cat.name %>
  </p>

  <div style="background: #fff8e1; padding: 10px 15px; border-left: 5px solid #f8b400; margin: 15px 0;">
    <strong>耳の状態（さくら耳）:</strong>
    <span style="font-size: 1.1em; color: #d32f2f; font-weight: bold;">
      <% case cat.ear_status %>
      <% when "right" %>
        右耳カット (オス ♂)
      <% when "left" %>
        左耳カット (メス ♀)
      <% else %>
        カットなし (未手術)
      <% end %>
    </span>
  </div>

  <p>
    <strong>その他情報・メモ:</strong><br>
    <%= simple_format(cat.description) %>
  </p>

  <p style="font-size: 0.8em; color: #888;">
    座標: <%= cat.latitude %>, <%= cat.longitude %>
  </p>
</div>