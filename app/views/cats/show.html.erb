<div style="padding: 20px; max-width: 800px; margin: 0 auto;">
  <%= link_to "← 一覧に戻る", cats_path %>

  <div style="margin-top: 20px;">
    <% if @cat.image.attached? %>
      <%= image_tag @cat.image.variant(resize_to_limit: [800, 800], format: :jpg), style: "width: 100%; border-radius: 15px;" %>
    <% end %>
  </div>

  <h1><%= @cat.name %></h1>
  <p><strong>耳の状態：</strong> <%= @cat.ear_status == "right" ? "右耳カット(♂)" : (@cat.ear_status == "left" ? "左耳カット(♀)" : "なし") %></p>
  <p><%= simple_format(@cat.description) %></p>

  <div style="margin: 20px 0; display: flex; gap: 10px;">
    <%# 編集ボタン（既存） %>
    <%= link_to "情報を書き換える", edit_cat_path(@cat), style: "padding: 10px 15px; background: #eee; text-decoration: none; border-radius: 5px; color: #333;" %>
  </div>

  <hr>

  <h3>発見場所</h3>
  <% if @cat.latitude && @cat.longitude %>
    <div id="show-map" style="width: 100%; height: 400px; border-radius: 10px; border: 1px solid #ddd;"></div>
    <script src="https://maps.googleapis.com/maps/api/js?key=<%= Rails.configuration.google_maps_api_key %>"></script>
   
    <script>
  function initShowMap() {
    // 重なり対策：同じ位置で撮影された場合、見た目上少しだけズラす（微小な乱数を足す）
    // ※ 0.0001は約10メートル程度のズレです
    const lat = <%= @cat.latitude %> + (Math.random() - 0.5) * 0.0002;
    const lng = <%= @cat.longitude %> + (Math.random() - 0.5) * 0.0002;
    const loc = { lat: lat, lng: lng };

    const map = new google.maps.Map(document.getElementById("show-map"), { 
      center: loc, 
      zoom: 16,
      mapTypeControl: false,
      streetViewControl: false
    });

    // ピンの色分け判定
    let pinImage;
    const status = "<%= @cat.ear_status %>";

    if (status === "right") {
      // 雄（右耳カット）：青いピン
      pinImage = "http://maps.google.com/mapfiles/ms/icons/blue-dot.png";
    } else if (status === "left") {
      // 雌（左耳カット）：赤いピン
      pinImage = "http://maps.google.com/mapfiles/ms/icons/red-dot.png";
    } else {
      // なし・不明：緑のピン
      pinImage = "http://maps.google.com/mapfiles/ms/icons/green-dot.png";
    }

    new google.maps.Marker({ 
      position: loc, 
      map: map,
      icon: pinImage,
      title: "<%= j @cat.name %>"
    });
  }
  window.onload = initShowMap;
</script>
  <% else %>
    <p style="color: #666; background: #f9f9f9; padding: 20px; border-radius: 10px;">位置情報が含まれていません。</p>
  <% end %>
</div>