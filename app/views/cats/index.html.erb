<%# 1-5行: 全体のレイアウト設定 %>
<div style="padding: 15px; font-family: sans-serif; max-width: 1000px; margin: 0 auto;">
  <h1 style="border-bottom: 4px solid #28a745; padding-bottom: 10px; font-size: 1.5em;">大田区 地域猫マップ</h1>

  <%# 7-10行: 「新しい猫を登録する」ボタン %>
  <div style="margin: 20px 0;">
    <%= link_to "＋ 新しい猫を登録する", new_cat_path, style: "background: #28a745; color: white; padding: 15px; text-decoration: none; border-radius: 10px; font-weight: bold; display: block; text-align: center; font-size: 1.2em; box-shadow: 0 4px 10px rgba(0,0,0,0.1);" %>
  </div>

  <%# 13行: 地図を表示する枠 %>
  <div id="main-map" style="width: 100%; height: 450px; border-radius: 15px; border: 2px solid #ddd; margin-bottom: 40px;"></div>

  <%# 16-30行: 下部の猫リスト表示（グリッド形式） %>
  <h2 style="border-left: 6px solid #28a745; padding-left: 10px; font-size: 1.2em;">登録猫リスト</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 15px;">
    <% @cats.each do |cat| %>
      <div style="border: 1px solid #eee; border-radius: 10px; overflow: hidden; background: white; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        <% if cat.image.attached? %>
          <%= image_tag cat.image.variant(resize_to_limit: [300, 300]), style: "width: 100%; height: 120px; object-fit: cover;" %>
        <% end %>
        <div style="padding: 8px;">
          <h3 style="margin: 0; font-size: 1.1em;"><%= cat.name %></h3>
          <p style="font-size: 0.8em; margin: 5px 0;">耳：<%= cat.ear_status == "right" ? "右(♂)" : (cat.ear_status == "left" ? "左(♀)" : "なし") %></p>
          <%= link_to "詳細を見る", cat, style: "color: #007bff; font-weight: bold; font-size: 0.9em;" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# 33行: Google Maps APIの読み込み %>
<script src="https://maps.googleapis.com/maps/api/js?key=<%= Rails.configuration.google_maps_api_key %>"></script>

<%# 36-60行: 地図の制御プログラム（JavaScript） %>
<script>
  function initMap() {
    const map = new google.maps.Map(document.getElementById("main-map"), {
      center: { lat: 35.5614, lng: 139.7161 }, zoom: 14
    });
    <% @cats.each do |cat| %>
      <% if cat.latitude && cat.longitude %>
        (function() {
          // ★ここが色分け機能
          let color = "green"; 
          <% if cat.ear_status == "right" %> color = "blue"; <% elsif cat.ear_status == "left" %> color = "red"; <% end %>
          
          const marker = new google.maps.Marker({
            position: { lat: <%= cat.latitude %>, lng: <%= cat.longitude %> },
            map: map,
            icon: `http://maps.google.com/mapfiles/ms/icons/${color}-dot.png`
          });

          // ★ここが吹き出し（詳細表示）機能
          const infoWindow = new google.maps.InfoWindow({
            content: '<div style="color:#333;"><strong><%= j cat.name %></strong><br><a href="/cats/<%= cat.id %>">詳細を見る</a></div>'
          });

          marker.addListener("click", () => {
            infoWindow.open(map, marker);
          });
        })();
      <% end %>
    <% end %>
  }
  window.onload = initMap;
</script>